\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Prediction accuracy for L1 and L2 fusion on real grouped regression datasets. Points show test RMSE means over five cross-validation folds, with horizontal bars showing the standard deviation. The vertical red lines indicate the full-pairwise baseline error which we want to preserve with the other methods. The exact active-edge L1 operator and active-edge L2 augmented-design solver preserve the reference RMSE, while the chain approximation is an approximate method.}}{19}{figure.5}\protected@file@percent }
\newlabel{fig:l1-l2-accuracy-three-datasets}{{5}{19}{Prediction accuracy for L1 and L2 fusion on real grouped regression datasets. Points show test RMSE means over five cross-validation folds, with horizontal bars showing the standard deviation. The vertical red lines indicate the full-pairwise baseline error which we want to preserve with the other methods. The exact active-edge L1 operator and active-edge L2 augmented-design solver preserve the reference RMSE, while the chain approximation is an approximate method}{figure.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Accuracy Preservation}{19}{subsection.6.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Fit time for the same datasets and solver families shown in Figure~\ref {fig:l1-l2-accuracy-three-datasets}. Bars show mean log$_{10}$ elapsed time in milliseconds over five cross-validation folds, with error bars showing the standard deviation. Lower values are better.}}{20}{figure.6}\protected@file@percent }
\newlabel{fig:l1-l2-timing-three-datasets}{{6}{20}{Fit time for the same datasets and solver families shown in Figure~\ref {fig:l1-l2-accuracy-three-datasets}. Bars show mean log$_{10}$ elapsed time in milliseconds over five cross-validation folds, with error bars showing the standard deviation. Lower values are better}{figure.6}{}}
