\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Real-data comparison between \texttt  {fusetune}{} and \texttt  {glmnet\_seeded}. Each point is a dataset. Values to the right of the vertical line indicate that \texttt  {fusetune}{} is faster; values below the horizontal line indicate that \texttt  {fusetune}{} attains lower test RMSE. The \(\ell _1\) panel shows a clear practical win for \texttt  {fusetune}. The \(\ell _2\) panel is more mixed on RMSE, but still strongly favors \texttt  {fusetune}{} on elapsed time.}}{8}{figure.caption.8}\protected@file@percent }
\newlabel{fig:real_efficiency}{{2}{8}{Real-data comparison between \codeid {} and \texttt {glmnet\_seeded}. Each point is a dataset. Values to the right of the vertical line indicate that \codeid {} is faster; values below the horizontal line indicate that \codeid {} attains lower test RMSE. The \(\ell _1\) panel shows a clear practical win for \codeid . The \(\ell _2\) panel is more mixed on RMSE, but still strongly favors \codeid {} on elapsed time}{figure.caption.8}{}}
